{
  "modelscope_api_key": {
    "description": "ModelScope API 密钥",
    "type": "string",
    "hint": "在 https://modelscope.cn/my/myaccesstoken 获取",
    "default": ""
  },
  "proxy_port": {
    "description": "代理服务监听端口",
    "type": "int",
    "default": 3473
  },
  "proxy_host": {
    "description": "代理服务监听地址",
    "type": "string",
    "default": "127.0.0.1",
    "hint": "建议保持 127.0.0.1 (仅本机访问)，若需外部访问可改为 0.0.0.0"
  },
  "proxy_api_key": {
    "description": "代理服务自身 API Key (可选)",
    "type": "string",
    "default": "",
    "hint": "留空则不启用验证；设置后可防止未授权访问"
  },
  "show_model_tag": {
    "description": "在回复文本头部注入 [模型名] 标识",
    "type": "bool",
    "default": false
  },
  "log_response": {
    "description": "将上游响应内容打印到日志（调试用）",
    "type": "bool",
    "default": false
  },
  "global_quota_reserve": {
    "description": "全局用户额度保留值（次）",
    "type": "int",
    "default": 0,
    "hint": "例如设为 10，则剩余额度 ≤10 时本插件将不再发起请求，保留至少 10 次给其他功能"
  },
  "virtual_models": {
    "description": "虚拟模型配置列表，每个虚拟模型有独立的模型回退列表和可选的兜底模型",
    "type": "template_list",
    "templates": {
      "default": {
        "name": "虚拟模型配置",
        "hint": "配置一个对外暴露的模型名称及其回退列表",
        "display_item": "name",
        "items": {
          "name": {
            "description": "虚拟模型名称（对外暴露）",
            "type": "string",
            "default": "modelscope-auto"
          },
          "model_list": {
            "description": "ModelScope 模型回退列表（按优先级排序）",
            "type": "list",
            "default": [],
            "hint": "示例：[\"deepseek-ai/DeepSeek-V4-Flash\", \"deepseek-ai/DeepSeek-V3.2\"]，至少配置一个"
          },
          "timeout": {
            "description": "请求超时时间（秒），包括连接和读取超时",
            "type": "int",
            "default": 120,
            "hint": "设置更长的时间，例如 120，以应对大模型生成慢的情况"
          },
          "fallback": {
            "description": "兜底模型配置（可选，当所有 ModelScope 模型不可用时使用）",
            "type": "object",
            "default": {},
            "items": {
              "api_key": {
                "description": "兜底 API 密钥",
                "type": "string",
                "default": ""
              },
              "base_url": {
                "description": "兜底 API 基础 URL（OpenAI 兼容）",
                "type": "string",
                "default": "https://api.openai.com/v1"
              },
              "model_name": {
                "description": "兜底模型名称",
                "type": "string",
                "default": "gpt-3.5-turbo"
              }
            }
          }
        }
      }
    },
    "default": [
      {
        "__template_key": "default",
        "name": "modelscope-auto",
        "model_list": [
          "ZhipuAI/GLM-5.2",
          "deepseek-ai/DeepSeek-V4-Pro",
          "ZhipuAI/GLM-5.1",
          "deepseek-ai/DeepSeek-V4-Flash",
          "Qwen/Qwen3-235B-A22B-Thinking-2507",
          "Qwen/Qwen3-235B-A22B"
        ],
        "timeout": 300
      },
      {
        "__template_key": "default",
        "name": "modelscope-auto-weak",
        "model_list": [
          "ZhipuAI/GLM-5",
          "MiniMax/MiniMax-M2.7",
          "deepseek-ai/DeepSeek-V3.2",
          "MiniMax/MiniMax-M2.5",
          "moonshotai/Kimi-K2.5",
          "stepfun-ai/Step-3.5-Flash",
          "MiniMax/MiniMax-M1-80k",
          "Qwen/Qwen3-235B-A22B-Thinking-2507",
          "Qwen/Qwen3-235B-A22B",
          "ZhipuAI/GLM-4.7-Flash"
        ],
        "timeout": 120
      },
      {
        "__template_key": "default",
        "name": "modelscope-auto-vision",
        "model_list": [
          "MiniMax/MiniMax-M3",
          "stepfun-ai/Step-3.7-Flash",
          "nex-agi/Nex-N2-Pro",
          "Qwen/Qwen3.5-397B-A17B",
          "Qwen/Qwen3.5-122B-A10B",
          "Qwen/Qwen3-VL-235B-A22B-Instruct",
          "Qwen/Qwen3.5-35B-A3B",
          "Qwen/Qwen3.5-27B"
        ],
        "timeout": 240
      }
    ]
  }
}
